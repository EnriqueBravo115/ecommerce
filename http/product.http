### POST create product
POST {{baseUrl}}/create
Authorization: {{token}}
Content-Type: application/json

{
  "category_id": 1,
  "sku": "LAPTOP-001",
  "name": "Gaming Laptop RTX",
  "description": "High performance gaming laptop",
  "short_description": "RTX Gaming Laptop",
  "price": 25000.00,
  "compare_at_price": 28000.00,
  "cost_price": 20000.00,
  "brand": "Asus",
  "weight": 2.5,
  "weight_unit": "kg",
  "status": "active",
  "condition": "new",
  "tags": "laptop,gaming,rtx"
}

### POST update product
POST {{baseUrl}}/update/1
Authorization: {{token}}
Content-Type: application/json

{
  "price": 24000.00,
  "compare_at_price": 26000.00,
  "status": "ACTIVE",
  "brand": "Asus ROG"
}

### DELETE product
DELETE {{baseUrl}}/delete/1
Authorization: {{token}}

### PUT increment view count
PUT {{baseUrl}}/view/1
Authorization: {{token}}

### GET my products
GET {{baseUrl}}/my-products
Authorization: {{token}}

### GET product by id
GET {{baseUrl}}/1
Authorization: {{token}}

### GET product by SKU
GET {{baseUrl}}/sku/TECH-LP-001
Authorization: {{token}}

### GET products by seller
GET {{baseUrl}}/seller/5
Authorization: {{token}}

### GET products by category
GET {{baseUrl}}/category/19
Authorization: {{token}}

### GET products by status
GET {{baseUrl}}/status/active
Authorization: {{token}}

### GET products by price range
GET {{baseUrl}}/price-range?min-price=100&max-price=500
Authorization: {{token}}

### GET top viewed products
GET {{baseUrl}}/top-viewed?limit=2
Authorization: {{token}}

### GET top rated products
GET {{baseUrl}}/top-rated?min-reviews=5&min-rating=4.5&limit=5
Authorization: {{token}}
